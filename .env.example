# .env.example — copy to .env and fill in your local overrides
# Environment variable overrides take highest priority over config.ini

# ── Browser settings ──────────────────────────────────────────────────────────
# Browser to use: chrome | firefox | edge
BROWSER=chrome

# Run in headless mode (true for CI, false for local dev with visible browser)
HEADLESS=false

# ── URL settings ──────────────────────────────────────────────────────────────
# Override base URL for testing against staging or local instance
BASE_URL=https://skillmantraedu.com

# ── Timeout settings ──────────────────────────────────────────────────────────
TIMEOUT=20

# ── Reporting ─────────────────────────────────────────────────────────────────
SCREENSHOT_ON_FAILURE=true

# ── Test environment ──────────────────────────────────────────────────────────
# Maps to a section in config.ini: DEFAULT | PROD | CI
TEST_ENV=DEFAULT
